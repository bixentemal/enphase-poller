          "rawSql": "WITH latest AS (\n  SELECT DISTINCT ON (serial_number)\n         serial_number,\n         watts,\n         max_watts,\n         source_reading_time\n  FROM inverter_readings\n  ORDER BY serial_number, source_reading_time DESC\n), fleet AS (\n  SELECT percentile_cont(0.5) WITHIN GROUP (ORDER BY watts) AS median_watts\n  FROM latest\n)\nSELECT l.serial_number,\n       l.watts,\n       ROUND(f.median_watts::numeric, 1) AS fleet_median_watts,\n       ROUND((l.watts - f.median_watts)::numeric, 1) AS delta_watts,\n       ROUND(CASE WHEN f.median_watts > 0 THEN ((l.watts - f.median_watts) / f.median_watts * 100)::numeric ELSE NULL END, 1) AS delta_pct,\n       ROUND(EXTRACT(EPOCH FROM (NOW() - l.source_reading_time))::numeric, 0) AS age_seconds,\n       l.source_reading_time AS last_report\nFROM latest l\nCROSS JOIN fleet f\nORDER BY delta_pct ASC, l.watts ASC",
