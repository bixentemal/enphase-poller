ENVOY_HOST=envoy.local
ENPHASE_TOKEN=your-jwt-token-here
DATABASE_URL=postgresql://enphase:changeme@localhost:5432/enphase

# Optional: polling intervals in seconds
# POLL_INTERVAL=30
# METER_REPORT_POLL_INTERVAL=60
# INVERTER_POLL_INTERVAL=300

# Optional: enable per-channel/per-phase meter data (~19M extra rows/year)
# ENABLE_CHANNEL_READINGS=false
